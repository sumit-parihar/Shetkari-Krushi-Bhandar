# ─────────────────────────────────────────
# Shetkari Krushi Bhandar — .gitignore
# ─────────────────────────────────────────

# ── Python / Backend ──────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.pdb

# Virtual environments
venv/
.venv/
env/
.env/
ENV/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# MyPy
.mypy_cache/

# ── Node / Frontend ───────────────────────
node_modules/
frontend/dist/
frontend/build/
frontend/.vite/

# ── Environment Files ─────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
backend/.env
frontend/.env

# Keep example files
!.env.example
!frontend/.env.example

# ── Database ──────────────────────────────
*.db
*.sqlite
*.sqlite3

# Keep SQL schema and seed files
!Databases/*.sql
!Databases/*.md
!Databases/*.txt

# ── OS Files ──────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ── IDE / Editor ──────────────────────────
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── Logs ──────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Misc ──────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
